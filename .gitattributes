# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files to always be normalized to LF line endings
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Denote all files that are truly binary and should not be modified
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
